---
import { Clock, Banknote, CalendarCheck } from "lucide-react";
---

<section class="relative bg-brand-blush py-16 md:py-24 overflow-hidden">
    <div
        class="container mx-auto px-6 grid md:grid-cols-2 gap-12 items-center relative z-10"
    >
        {/* Text Content */}
        <div class="max-w-xl animate-fade-in-up">
            <div
                class="inline-block bg-brand-coral/10 text-brand-coral font-bold px-4 py-1.5 rounded-full text-sm uppercase tracking-wide mb-6"
            >
                Gesucht: Mamas für kurzes Interview
            </div>

            <h1
                class="font-heading font-extrabold text-4xl md:text-5xl lg:text-6xl text-brand-navy leading-tight mb-6"
            >
                Deine Erfahrungen als Mama sind <br />
                <span class="text-brand-coral relative">
                    Gold wert! ✨
                    {/* Subtle underline SVG */}
                    <svg
                        class="absolute w-full h-3 -bottom-1 left-0 text-brand-sand opacity-50 z-[-1]"
                        viewBox="0 0 100 10"
                        preserveAspectRatio="none"
                    >
                        <path
                            d="M0 5 Q 50 10 100 5"
                            stroke="currentColor"
                            stroke-width="8"
                            fill="none"
                            stroke-linecap="round"></path>
                    </svg>
                </span>
            </h1>

            <p class="text-lg md:text-xl text-brand-navy/80 mb-8 max-w-lg">
                Wie sieht euer Alltag wirklich aus? Für ein spannendes, neues
                Projekt suchen wir Mütter für ein kurzes, entspanntes
                Online-Interview. Keine Vorbereitung nötig!
            </p>

            {/* Quick Facts */}
            <div class="flex flex-col sm:flex-row gap-4 mb-10">
                <div
                    class="flex items-center gap-3 bg-white/60 px-5 py-3 rounded-xl shadow-sm border border-white"
                >
                    <Clock className="w-5 h-5 text-brand-teal" />
                    <span class="font-medium text-brand-navy">30 Minuten</span>
                </div>
                <div
                    class="flex items-center gap-3 bg-white/60 px-5 py-3 rounded-xl shadow-sm border border-white"
                >
                    <Banknote className="w-5 h-5 text-brand-coral" />
                    <span class="font-medium text-brand-navy"
                        >40€ Dankeschön</span
                    >
                </div>
                <div
                    class="flex items-center gap-3 bg-white/60 px-5 py-3 rounded-xl shadow-sm border border-white"
                >
                    <CalendarCheck className="w-5 h-5 text-brand-teal" />
                    <span class="font-medium text-brand-navy"
                        >Über Google Meet</span
                    >
                </div>
            </div>

            {/* CTA Layer */}
            <div>
                <a
                    href="#screener"
                    class="inline-block bg-brand-coral hover:bg-brand-coral/90 text-white font-heading font-bold text-lg px-8 py-4 rounded-xl shadow-lg hover:shadow-xl hover:-translate-y-0.5 transition-all"
                >
                    👉 Jetzt Kurz-Check starten (Dauert nur 60 Sekunden)
                </a>
                <p class="text-sm text-brand-navy/60 mt-4">
                    Unverbindlich & DSGVO-konform
                </p>
            </div>
        </div>

        {/* Image / Video Layer */}
        <div class="relative animate-fade-in-up" style="animation-delay: 0.2s;">
            <div
                class="relative rounded-3xl overflow-hidden aspect-[4/5] object-cover shadow-2xl border-4 border-white/50 group"
            >
                {/* Platzhalter-Bild: Hier später via Midjourney ersetzen */}
                <div
                    class="w-full h-full bg-brand-navy/5 flex items-center justify-center absolute inset-0"
                >
                    <img
                        src="/muttertochter.png"
                        alt="Mutter und Tochter beim Lesen"
                        class="w-full h-full object-cover grayscale-[10%]"
                    />
                </div>
            </div>

            {/* Floating Trust Badge */}
            <div
                class="absolute bottom-6 right-6 bg-white/90 backdrop-blur px-4 py-3 rounded-2xl shadow-xl flex items-center gap-3"
            >
                <div class="bg-brand-teal/20 p-2 rounded-full">
                    <Banknote className="w-6 h-6 text-brand-teal" />
                </div>
                <div>
                    <p
                        class="text-xs font-bold text-brand-navy uppercase tracking-wider"
                    >
                        Auszahlung
                    </p>
                    <p class="text-sm font-medium text-brand-navy/80">
                        Per PayPal nach Call
                    </p>
                </div>
            </div>
        </div>

        {/* Decorative Blob */}
        <div
            class="absolute -top-10 -right-10 w-40 h-40 bg-brand-sand/50 rounded-full mix-blend-multiply filter blur-2xl z-[-1]"
        >
        </div>
        <div
            class="absolute -bottom-10 -left-10 w-40 h-40 bg-brand-coral/20 rounded-full mix-blend-multiply filter blur-2xl z-[-1]"
        >
        </div>
    </div>
</section>

<style>
    @keyframes fadeInUp {
        from {
            opacity: 0;
            transform: translateY(20px);
        }
        to {
            opacity: 1;
            transform: translateY(0);
        }
    }
    .animate-fade-in-up {
        animation: fadeInUp 0.8s cubic-bezier(0.16, 1, 0.3, 1) forwards;
    }
</style>

---
import Layout from "../layouts/Layout.astro";
---

<Layout
    title="Interview Portal | Marktforschung Kinderbücher"
    description="Sicherer Zugang zur Befragung während des Interviews"
>
    <div
        class="flex-grow flex items-center justify-center bg-brand-blush/30 py-12 px-6"
    >
        {/* State container */}
        <div
            id="gatekeeper"
            class="max-w-md w-full bg-white p-8 rounded-3xl shadow-xl border border-brand-sand/30 text-center transition-all"
        >
            <h2
                class="font-heading font-extrabold text-3xl text-brand-navy mb-4"
            >
                Willkommen!
            </h2>
            <p class="text-brand-navy/70 mb-8">
                Bitte gib den Zugangscode ein, den ich dir gerade im Google Meet
                Call genannt habe.
            </p>

            <form id="login-form" class="space-y-4">
                <input
                    type="text"
                    id="pin-input"
                    placeholder="Zugangscode (z.B. BUCH26)"
                    required
                    class="w-full text-center text-xl tracking-widest px-4 py-4 rounded-xl border-2 border-gray-200 focus:border-brand-coral focus:ring-0 outline-none uppercase transition-all"
                />
                <p id="error-msg" class="text-red-500 text-sm hidden">
                    Falscher Code. Bitte nochmal probieren.
                </p>
                <button
                    type="submit"
                    class="w-full bg-brand-navy hover:bg-brand-navy/90 text-white font-bold py-4 rounded-xl shadow-md transition-all"
                >
                    Befragung starten
                </button>
            </form>
        </div>

        {/* Survey Container (Hidden initially) */}
        <div id="survey-container" class="max-w-4xl w-full hidden">
            <div
                class="bg-white p-8 md:p-12 rounded-3xl shadow-xl border border-brand-sand/30"
            >
                <div
                    class="mb-8 border-b border-gray-100 pb-4 flex justify-between items-end"
                >
                    <div>
                        <h2
                            class="font-heading font-extrabold text-2xl md:text-3xl text-brand-navy"
                        >
                            Interview Befragung
                        </h2>
                        <p class="text-brand-navy/60">
                            Bitte fülle dies nun gemeinsam mit mir aus.
                        </p>
                    </div>
                    <span
                        class="text-sm font-bold text-brand-coral bg-brand-coral/10 px-3 py-1 rounded-full"
                        >Phase 1</span
                    >
                </div>

                {/* Embed Tally / Survey logic here later */}
                <div
                    class="aspect-video bg-gray-50 rounded-xl border-2 border-dashed border-gray-200 flex items-center justify-center text-gray-400"
                >
                    <p>
                        [Hier wird die eigentliche Befragung via Tally.so iframe
                        eingebettet]
                    </p>
                </div>
            </div>
        </div>
    </div>

    <script>
        const form = document.getElementById("login-form");
        const input = document.getElementById("pin-input") as HTMLInputElement;
        const errorMsg = document.getElementById("error-msg");
        const gatekeeper = document.getElementById("gatekeeper");
        const surveyContainer = document.getElementById("survey-container");

        // Simple client-side gate (not high security, but perfect for a live 1-on-1 interview)
        const SECRET_PIN = "BUCH26";

        form?.addEventListener("submit", (e) => {
            e.preventDefault();
            if (input?.value.toUpperCase().trim() === SECRET_PIN) {
                gatekeeper?.classList.add("hidden");
                surveyContainer?.classList.remove("hidden");
                surveyContainer?.classList.add(
                    "animate-in",
                    "fade-in",
                    "zoom-in-95",
                    "duration-500",
                );
            } else {
                errorMsg?.classList.remove("hidden");
                input?.classList.add("border-red-500", "bg-red-50");
                setTimeout(() => {
                    input?.classList.remove("border-red-500", "bg-red-50");
                }, 1000);
            }
        });
    </script>
</Layout>
